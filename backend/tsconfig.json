{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@backend/*": ["./src/*"],
      "@prisma/client": ["./node_modules/@prisma/client"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
